---
/* PROJECT CONTEXT: - Astro project (movies app tipo IMDb) - Data comes from
TMDB API - Layout: - MainLayout.astro - Components: - MovieCard.astro →
renderiza cada película - Pages: - index.astro → home - search.astro → búsqueda
- movie/[id].astro → detalle de película - actor/[id].astro → detalle de actor -
browse/[slug].astro → listas por género/año GOAL: - Improve UI without breaking
logic - Do not change routes unless explicitly requested */

const { movie } = Astro.props;
const releaseYear = movie.release_date?.split("-")[0] || "Sin fecha";
const rating = movie.vote_average ? movie.vote_average.toFixed(1) : "N/A";
---

<style>
  .card {
    position: relative;
    display: block;
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    color: white;
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease;
  }

  .card:hover {
    transform: scale(1.08);
    box-shadow: 0 24px 48px rgba(229, 9, 20, 0.3);
  }

  .poster {
    width: 100%;
    height: auto;
    display: block;
    transition: filter 0.3s ease;
  }

  .card:hover .poster {
    filter: brightness(0.75);
  }

  .info {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 12px;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.9), transparent);
    transition: background 0.3s ease;
  }

  .card:hover .info {
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.95),
      rgba(0, 0, 0, 0.2)
    );
  }

  .title {
    font-size: 1rem;
    font-weight: bold;
    margin-bottom: 4px;
  }

  .meta {
    font-size: 0.85rem;
    color: #bbb;
  }
</style>

<a
  class="card"
  href={`/movie/${movie.id}`}
  data-title={movie.title.toLowerCase()}
>
  <img
    class="poster"
    src={`https://image.tmdb.org/t/p/w500${movie.poster_path}`}
    alt={movie.title}
    loading="lazy"
  />

  <div class="info">
    <p class="title">{movie.title}</p>
    <p class="meta">⭐ {rating}/10 · {releaseYear}</p>
  </div>
</a>
