---
const { title = "Películas de terror" } = Astro.props;
const path = Astro.url.pathname;
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;600&display=swap"
      rel="stylesheet"
    />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>

    <style>
      body {
        margin: 0;
        font-family: "Inter", sans-serif;
        background: #111;
        color: white;
      }

      a {
        color: white;
        text-decoration: none;
      }

      .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 40px 20px;
      }

      h1,
      h2,
      h3 {
        font-family: "Bebas Neue", sans-serif;
        letter-spacing: 1px;
        margin-top: 0;
        margin-bottom: 16px;
      }

      h1 {
        font-size: 3rem;
      }

      p {
        color: #cfcfcf;
        font-size: 1.1rem;
        margin-bottom: 24px;
      }

      select {
        padding: 12px 16px;
        font-size: 16px;
        border-radius: 8px;
        border: 1px solid #444;
        background: #222;
        color: white;
        min-width: 220px;
      }

      .site-header {
        position: sticky;
        top: 0;
        z-index: 50;
        background: rgba(10, 10, 10, 0.82);
        backdrop-filter: blur(8px);
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
      }

      .site-header__inner {
        max-width: 1200px;
        margin: 0 auto;
        padding: 14px 20px;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      .site-logo {
        font-family: "Bebas Neue", sans-serif;
        font-size: 28px;
        letter-spacing: 1px;
        color: white;
      }

      .site-nav {
        display: flex;
        align-items: center;
        gap: 10px;
      }

      .site-nav a {
        color: #d6d6d6;
        font-size: 14px;
        padding: 8px 12px;
        border-radius: 8px;
        transition:
          background 0.2s ease,
          color 0.2s ease;
      }

      .site-nav a:hover {
        color: white;
        background: rgba(255, 255, 255, 0.08);
      }

      .site-logo {
        display: flex;
        align-items: center;
        gap: 8px;
      }

      .site-logo__icon {
        font-size: 22px;
      }

      .site-logo__text {
        font-family: "Bebas Neue", sans-serif;
        font-size: 26px;
        letter-spacing: 1px;
      }

      .site-nav a.active {
        color: white;
        background: rgba(255, 0, 0, 0.828);
      }
    </style>
  </head>

  <body>
    <header class="site-header">
      <div class="site-header__inner">
        <a class="site-logo" href="/">🎬 Movies</a>

        <nav class="site-nav">
          <a href="/" class={path === "/" ? "active" : ""}>Inicio</a>
          <a href="/search" class={path.startsWith("/search") ? "active" : ""}
            >Buscar</a
          >
        </nav>
      </div>
    </header>

    <slot />
  </body>
</html>
