---
import MainLayout from "../layouts/MainLayout.astro";
import MovieCard from "../components/MovieCard.astro";
import heroImage from "../assets/back.png";

const currentYear = new Date().getFullYear();
const startYear = 1900;
const years = [];

const apiKey = import.meta.env.TMDB_API_KEY;

const popularUrl = `https://api.themoviedb.org/3/discover/movie?api_key=${apiKey}&with_genres=27,878&sort_by=popularity.desc&language=es-ES`;

const popularResponse = await fetch(popularUrl);
const popularData = await popularResponse.json();

const popularMovies = popularData.results || [];

for (let year = currentYear; year >= startYear; year--) {
  years.push(year);
}
---

<MainLayout title="Películas de terror">
  <style>
    .hero {
      min-height: 78vh;
      display: grid;
      place-items: center;
      padding: 40px 20px;
      position: relative;
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
    }

    .hero-content {
      width: 100%;
      max-width: 820px;
      text-align: center;
      background: rgba(12, 12, 12, 0.72);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 20px;
      padding: 48px 28px;
      backdrop-filter: blur(6px);
      box-shadow: 0 20px 50px rgba(0, 0, 0, 0.45);
    }

    .eyebrow {
      margin: 0 0 10px;
      color: #e50914;
      font-size: 14px;
      letter-spacing: 1px;
      text-transform: uppercase;
    }

    h1 {
      margin: 0 0 16px;
      font-size: 4rem;
      line-height: 1;
    }

    .subtitle {
      max-width: 680px;
      margin: 0 auto 28px;
      color: #d6d6d6;
      font-size: 1.1rem;
      line-height: 1.6;
    }

    .hero-actions {
      display: flex;
      justify-content: center;
      gap: 12px;
      flex-wrap: wrap;
      margin-bottom: 28px;
    }

    .hero-button {
      display: inline-block;
      padding: 12px 18px;
      border-radius: 8px;
      font-size: 15px;
      font-weight: 600;
      text-decoration: none;
      transition:
        transform 0.15s ease,
        box-shadow 0.15s ease,
        background 0.15s ease;
    }

    .hero-button:hover {
      transform: translateY(-2px);
    }

    .hero-button--primary {
      background: #e50914;
      color: white;
    }

    .hero-button--primary:hover {
      box-shadow: 0 8px 18px rgba(0, 0, 0, 0.4);
    }

    .hero-button--secondary {
      background: rgba(255, 255, 255, 0.08);
      color: white;
      border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .picker-box {
      margin-top: 10px;
    }

    select {
      width: 100%;
      max-width: 320px;
      padding: 12px 14px;
      margin: 6px auto;
      display: block;
      background: #1c1c1c;
      color: white;
      border: 1px solid #333;
      border-radius: 8px;
      font-size: 16px;
    }

    button {
      margin-top: 16px;
      padding: 12px 22px;
      background: #e50914;
      color: white;
      border: none;
      border-radius: 8px;
      font-size: 16px;
      font-weight: 600;
      cursor: pointer;
      transition:
        transform 0.15s ease,
        box-shadow 0.15s ease;
    }

    button:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 18px rgba(0, 0, 0, 0.4);
    }

    @media (max-width: 768px) {
      .hero-content {
        padding: 36px 20px;
      }

      h1 {
        font-size: 3rem;
      }

      .subtitle {
        font-size: 1rem;
      }
    }

    .popular-section {
      padding: 10px 40px 60px;
    }

    .popular-section h2 {
      margin-bottom: 20px;
    }

    .popular-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 24px;
      padding: 0 20px;
    }
    @media (max-width: 768px) {
      .popular-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <main
    class="hero"
    style={`background-image:
      linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.85)),
      url(${heroImage.src});`}
  >
    <div class="hero-content">
      <p class="eyebrow">Catálogo de cine</p>
      <h1>TERROR & SCI-FI Prueba</h1>
      <p class="subtitle">
        Explora películas por género y año, descubre actores y navega entre
        títulos como en una pequeña plataforma de cine.
      </p>

      <div class="hero-actions">
        <button class="hero-button hero-button--primary" id="explore-horror">
          Explorar terror
        </button>

        <button class="hero-button hero-button--secondary" id="explore-scifi">
          Explorar sci-fi
        </button>
      </div>

      <div class="picker-box">
        <select id="genre">
          <option value="">Selecciona un género</option>
          <option value="horror">Terror</option>
          <option value="scifi">Ciencia ficción</option>
        </select>

        <select id="year">
          <option value="">Selecciona un año</option>

          {years.map((year) => <option value={year}>{year}</option>)}
        </select>

        <button id="go">Ver películas</button>
      </div>

      <script>
        const genre = document.getElementById("genre");
        const year = document.getElementById("year");
        const button = document.getElementById("go");
        const exploreHorror = document.getElementById("explore-horror");
        const exploreScifi = document.getElementById("explore-scifi");
        exploreHorror?.addEventListener("click", () => {
          const selectedYear = year.value || new Date().getFullYear();
          window.location.href = `/browse/horror-${selectedYear}`;
        });

        exploreScifi?.addEventListener("click", () => {
          const selectedYear = year.value || new Date().getFullYear();
          window.location.href = `/browse/scifi-${selectedYear}`;
        });

        button?.addEventListener("click", () => {
          if (genre.value && year.value) {
            window.location.href = `/browse/${genre.value}-${year.value}`;
          }
        });
      </script>
    </div>
  </main>
  <section class="popular-section container">
    <h2>Populares ahora</h2>

    <div class="popular-grid">
      {popularMovies.slice(0, 8).map((movie) => <MovieCard movie={movie} />)}
    </div>
  </section>
</MainLayout>
