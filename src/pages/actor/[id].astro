---
export const prerender = false;
import MainLayout from "../../layouts/MainLayout.astro";
import MovieCard from "../../components/MovieCard.astro";

const apiKey = import.meta.env.TMDB_API_KEY;
const id = Astro.params.id;

const personUrl = `https://api.themoviedb.org/3/person/${id}?api_key=${apiKey}&language=es-ES`;

const personResponse = await fetch(personUrl);
const person = await personResponse.json();

const creditsUrl = `https://api.themoviedb.org/3/person/${id}/movie_credits?api_key=${apiKey}&language=es-ES`;

const creditsResponse = await fetch(creditsUrl);
const creditsData = await creditsResponse.json();

const movies = (creditsData.cast || [])
  .filter((movie) => movie.poster_path)
  .sort((a, b) => b.popularity - a.popularity);
---

<MainLayout title={person.name}>
  <style>
    .container {
      max-width: 1100px;
      margin: 0 auto;
      padding: 40px 20px;
    }

    .actor-header {
      display: grid;
      grid-template-columns: 280px 1fr;
      gap: 40px;
      align-items: start;
      margin-bottom: 50px;
    }

    .actor-photo {
      width: 100%;
      border-radius: 12px;
      display: block;
    }

    .actor-info h1 {
      margin-top: 0;
      margin-bottom: 20px;
    }

    .actor-meta {
      margin-bottom: 20px;
      color: #bbb;
    }

    .actor-meta p {
      margin: 4px 0;
      font-size: 14px;
    }

    .biography p {
      line-height: 1.7;
      color: #ddd;
    }

    .movies-section {
      margin-top: 20px;
    }

    .movies-grid {
      margin-top: 20px;
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 24px;
    }

    @media (max-width: 768px) {
      .actor-header {
        grid-template-columns: 1fr;
      }

      .movies-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <main class="container">
    <section class="actor-header">
      <div>
        {
          person.profile_path && (
            <img
              class="actor-photo"
              src={`https://image.tmdb.org/t/p/w500${person.profile_path}`}
              alt={person.name}
            />
          )
        }
      </div>

      <div class="actor-info">
        <h1>{person.name}</h1>
        <div class="actor-meta">
          {
            person.birthday && (
              <p>
                <strong>Nacimiento:</strong> {person.birthday}
              </p>
            )
          }
          {
            person.place_of_birth && (
              <p>
                <strong>Lugar:</strong> {person.place_of_birth}
              </p>
            )
          }
        </div>

        {
          person.biography && (
            <div class="biography">
              <h2>Biografía</h2>
              <p>{person.biography}</p>
            </div>
          )
        }
      </div>
    </section>

    <section class="movies-section">
      <h2>Películas</h2>

      <div class="movies-grid">
        {movies.slice(0, 8).map((movie) => <MovieCard movie={movie} />)}
      </div>
    </section>
  </main>
</MainLayout>
