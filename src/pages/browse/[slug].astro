---
export const prerender = false;
import MainLayout from "../../layouts/MainLayout.astro";
import MovieCard from "../../components/MovieCard.astro";

const apiKey = import.meta.env.TMDB_API_KEY;
const slug = Astro.params.slug || "";

const [genre, year] = slug.split("-");

let genreId = "27";
let genreLabel = "Terror";

if (genre === "scifi") {
  genreId = "878";
  genreLabel = "Ciencia ficción";
}

const page = Number(Astro.url.searchParams.get("page") || 1);

const url = `https://api.themoviedb.org/3/discover/movie?api_key=${apiKey}&with_genres=${genreId}&primary_release_year=${year}&page=${page}&language=es-ES`;

const response = await fetch(url);
const data = await response.json();

const movies = data.results || [];
---

<MainLayout title={`${genreLabel} ${year}`}>

  <style>
    * {
      box-sizing: border-box;
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 40px 20px;
    }

    .topbar {
      margin-bottom: 24px;
    }

    .back {
      color: white;
      text-decoration: none;
      font-size: 14px;
    }

    .back:hover {
      text-decoration: underline;
    }

    .grid {
      margin-top: 30px;
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 24px;
    }

    .pagination {
      margin-top: 40px;
      display: flex;
      gap: 20px;
      align-items: center;
      flex-wrap: wrap;
    }

    .pagination a {
      color: white;
      text-decoration: none;
      background: #222;
      padding: 10px 14px;
      border-radius: 8px;
    }

    .pagination span {
      color: #ccc;
    }

    @media (max-width: 768px) {
      .grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <main class="container">
    <div class="topbar">
      <a class="back" href="/">← Inicio</a>
    </div>

    <h1>{genreLabel} {year}</h1>

    <div class="grid">
      {movies.map((movie) => (
        <MovieCard movie={movie} />
      ))}
    </div>

    <div class="pagination">
      {page > 1 && (
        <a href={`/browse/${genre}-${year}?page=${page - 1}`}>
          ← Anterior
        </a>
      )}

      <span>Página {page}</span>

      <a href={`/browse/${genre}-${year}?page=${page + 1}`}>
        Siguiente →
      </a>
    </div>
  </main>

</MainLayout>